# Logging
LOG_LEVEL=INFO                     # Python log level: DEBUG, INFO, WARNING, ERROR, CRITICAL

# Database
DATABASE_URL=sqlite:///./hospital.db  # SQLite database path

# JWT Authentication
JWT_SECRET=super-secret-key        # Secret key for signing JWT tokens
JWT_ALGORITHM=HS256                # JWT signing algorithm
JWT_EXPIRATION_MINUTES=60          # Token expiry in minutes

# AWS Configuration
AWS_REGION=us-east-1               # AWS region for SQS and S3
SQS_QUEUE_URL=                     # AWS SQS queue URL (leave empty for local dev)
S3_BUCKET_NAME=hospital-events     # AWS S3 bucket name
AWS_ENDPOINT_URL=                  # AWS endpoint URL (set for LocalStack, leave empty for real AWS)
