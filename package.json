{
  "name": "hospital-event-simulation",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "uv run fastapi dev",
    "start": "uv run uvicorn app.main:app --host 0.0.0.0 --port 8000",
    "format": "uv run ruff format .",
    "format:check": "uv run ruff format --check .",
    "lint": "uv run ruff check .",
    "lint:fix": "uv run ruff check --fix .",
    "typecheck": "uv run mypy app/",
    "typecheck:strict": "uv run mypy --strict app/",
    "check": "npm run format:check && npm run lint && npm run typecheck",
    "seed": "uv run python -m app.seed",
    "sync": "uv sync",
    "build": "docker compose build",
    "up": "docker compose up -d",
    "down": "docker compose down"
  }
}
